; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Parallaxa_card"
config/description="Parallaxa Card - Godot 4.7 clean infrastructure base derived from parallaxa_orange. Ships autoloads (settings, localization, save, audio, input, scene transition, screen effects, cursor), PhantomCamera + Dialogue Manager, the UI theme and localization, with no gameplay yet. Boots into the empty main scene. See docs/ARCHITECTURE.md."
run/main_scene="res://src/main/main.tscn"
config/features=PackedStringArray("4.7", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

PhantomCameraManager="*res://addons/phantom_camera/scripts/managers/phantom_camera_manager.gd"
DialogueManager="*res://addons/dialogue_manager/dialogue_manager.gd"
Settings="*res://src/autoload/settings_manager.gd"
Localization="*res://src/autoload/localization.gd"
SaveManager="*res://src/autoload/save_manager.gd"
AudioManager="*res://src/autoload/audio_manager.gd"
InputManager="*res://src/autoload/input_manager.gd"
SceneTransition="*res://src/autoload/scene_transition.gd"
ScreenEffects="*res://src/autoload/screen_effects.gd"
CursorManager="*res://src/autoload/cursor_manager.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[editor_plugins]

enabled=PackedStringArray("res://addons/phantom_camera/plugin.cfg", "res://addons/dialogue_manager/plugin.cfg")

[gui]

theme/custom="res://assets/ui/theme/ui_theme.tres"
theme/custom_font="res://assets/fonts/monogram-extended.ttf"

